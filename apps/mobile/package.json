{
  "name": "@hahatalk/mobile",
  "version": "0.17.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "assets": "powershell -ExecutionPolicy Bypass -File scripts/generate-mobile-assets.ps1",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "npm run typecheck && expo install --check",
    "export:android": "expo export --platform android --output-dir dist/android --clear",
    "export:ios": "expo export --platform ios --output-dir dist/ios --clear",
    "build": "npm run typecheck && npm run export:android && npm run export:ios"
  },
  "dependencies": {
    "@hahatalk/contracts": "0.1.0",
    "@livekit/react-native": "2.11.1",
    "@livekit/react-native-expo-plugin": "1.0.2",
    "@livekit/react-native-webrtc": "144.1.1",
    "@react-native-community/netinfo": "12.0.1",
    "expo": "~57.0.4",
    "expo-application": "~57.0.0",
    "expo-constants": "~57.0.3",
    "expo-crypto": "~57.0.0",
    "expo-device": "~57.0.0",
    "expo-document-picker": "~57.0.0",
    "expo-file-system": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-image-picker": "~57.0.2",
    "expo-linking": "~57.0.2",
    "expo-notifications": "~57.0.3",
    "expo-router": "~57.0.4",
    "expo-secure-store": "~57.0.0",
    "expo-sharing": "~57.0.0",
    "expo-splash-screen": "~57.0.2",
    "expo-sqlite": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-video": "~57.0.0",
    "livekit-client": "2.20.1",
    "lucide-react-native": "1.24.0",
    "react": "19.2.7",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.5",
    "react-native-worklets": "0.10.0",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "typescript": "~6.0.3"
  },
  "expo": {
    "install": {
      "exclude": [
        "react",
        "react-native-svg"
      ]
    }
  }
}
