{
  "name": "hahatalk",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,green \"npm run dev -w apps/api\" \"npm run dev -w apps/web\"",
    "dev:web": "npm run dev -w apps/web",
    "dev:api": "npm run dev -w apps/api",
    "infra:up": "docker compose up -d --wait",
    "infra:down": "docker compose down",
    "infra:status": "docker compose ps",
    "infra:postgres:portable": "powershell -ExecutionPolicy Bypass -File tools/dev/portable-postgres.ps1 -Action Start",
    "infra:postgres:portable:stop": "powershell -ExecutionPolicy Bypass -File tools/dev/portable-postgres.ps1 -Action Stop",
    "infra:livekit:portable": "powershell -ExecutionPolicy Bypass -File tools/dev/portable-livekit.ps1",
    "media-infra:prepare": "node tools/infra/render-media-deployment.mjs --generate-smoke-secrets",
    "media-infra:check": "node tools/harness/media-infrastructure-config.mjs",
    "media-infra:smoke": "node tools/harness/media-egress-smoke.mjs",
    "dev:desktop": "concurrently -k -n api,web,desktop -c cyan,green,magenta \"npm run dev -w apps/api\" \"npm run dev -w apps/web\" \"wait-on http://127.0.0.1:4000/health http://127.0.0.1:3000 && npm run dev -w apps/desktop\"",
    "desktop:runtime": "npm run runtime:build -w apps/desktop",
    "desktop:package": "npm run runtime:build -w apps/desktop && npm run package -w apps/desktop",
    "desktop:make": "npm run runtime:build -w apps/desktop && npm run make -w apps/desktop",
    "desktop:check": "node tools/harness/windows-desktop-check.mjs",
    "desktop:smoke": "powershell -ExecutionPolicy Bypass -File tools/harness/windows-package-smoke.ps1",
    "desktop:renderer-smoke": "node tools/harness/windows-renderer-auth-smoke.mjs",
    "desktop:call-renderer-smoke": "node tools/harness/windows-call-renderer-smoke.mjs",
    "desktop:meeting-renderer-smoke": "node tools/harness/windows-meeting-renderer-smoke.mjs",
    "desktop:broadcast-renderer-smoke": "node tools/harness/windows-broadcast-renderer-smoke.mjs",
    "desktop:ai-renderer-smoke": "node tools/harness/windows-ai-renderer-smoke.mjs",
    "auth:integration": "node tools/harness/auth-persistence.mjs",
    "invitation:integration": "node tools/harness/invitation-consent.mjs",
    "conversation:integration": "node tools/harness/conversation-persistence.mjs",
    "contacts:integration": "node tools/harness/contacts-privacy.mjs",
    "media:integration": "node tools/harness/media-document-desk.mjs",
    "calendar:integration": "node tools/harness/schedule-rsvp-reminders.mjs",
    "calls:integration": "node tools/harness/livekit-call-core.mjs",
    "meetings:integration": "node tools/harness/scheduled-meeting-lobby.mjs",
    "broadcasts:integration": "node tools/harness/personal-broadcast.mjs",
    "ai:integration": "node tools/harness/ai-voice-workbench.mjs",
    "remote-support:integration": "node tools/harness/consented-remote-support.mjs",
    "mobile:integration": "node tools/harness/mobile-companion.mjs",
    "mobile:check": "npm run check -w apps/mobile && node tools/harness/mobile-bundle-check.mjs",
    "mobile:export": "npm run export:android -w apps/mobile && npm run export:ios -w apps/mobile",
    "mobile:bundle-check": "node tools/harness/mobile-bundle-check.mjs --require-bundles",
    "release:integration": "node tools/harness/release-hardening.mjs",
    "release:load": "node tools/harness/release-load-reconnect.mjs",
    "release:artifact-check": "node tools/harness/release-artifact-check.mjs",
    "release:manifest": "node tools/release/create-release-manifest.mjs",
    "release:sbom": "node tools/release/create-sbom.mjs",
    "release:quality": "npm run typecheck && npm run test && npm run schema:check && npm run build && npm run release:artifact-check && npm run release:integration && npm run release:load",
    "assistant:integration": "node tools/harness/local-assistant-chat.mjs",
    "data:reset:installed": "node tools/maintenance/reset-installed-test-data.mjs",
    "screen-share:integration": "npm run calls:integration && npm run meetings:integration",
    "recording:integration": "npm run calls:integration && npm run meetings:integration",
    "desktop:stage6d-renderer-smoke": "npm run desktop:call-renderer-smoke && npm run desktop:meeting-renderer-smoke",
    "desktop:stage6e-renderer-smoke": "npm run desktop:call-renderer-smoke && npm run desktop:meeting-renderer-smoke",
    "desktop:stage6f-renderer-smoke": "npm run desktop:call-renderer-smoke && npm run desktop:meeting-renderer-smoke",
    "desktop:stage7-renderer-smoke": "npm run desktop:broadcast-renderer-smoke",
    "desktop:stage8-renderer-smoke": "npm run desktop:ai-renderer-smoke",
    "desktop:stage9-renderer-smoke": "node tools/harness/windows-remote-support-renderer-smoke.mjs",
    "desktop:remote-agent-process-smoke": "\".\\apps\\desktop\\node_modules\\.bin\\electron.cmd\" tools\\harness\\windows-remote-agent-process-smoke.cjs",
    "build": "npm run build -w packages/contracts && npm run build -w apps/api && npm run build -w apps/web && npm run build -w apps/mobile && npm run build -w apps/desktop",
    "typecheck": "npm run typecheck -w packages/contracts && npm run typecheck -w apps/api && npm run typecheck -w apps/web && npm run typecheck -w apps/mobile && npm run typecheck -w apps/desktop",
    "test": "npm run test -w packages/contracts",
    "smoke": "node tools/harness/smoke.mjs",
    "schema:check": "node tools/harness/schema-check.mjs",
    "harness": "powershell -ExecutionPolicy Bypass -File tools/harness/hahatalk-harness.ps1",
    "report:new": "powershell -ExecutionPolicy Bypass -File tools/harness/new-obsidian-report.ps1",
    "dev:loop": "powershell -ExecutionPolicy Bypass -File tools/harness/development-loop.ps1",
    "lint": "npm run typecheck"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1086.0",
    "concurrently": "^9.1.2",
    "socket.io-client": "^4.8.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.3",
    "yaml": "^2.9.0"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "tar": "7.5.19",
    "tmp": "0.2.7"
  }
}
