{
  "name": "hahatalk",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,green \"npm run dev -w apps/api\" \"npm run dev -w apps/web\"",
    "dev:web": "npm run dev -w apps/web",
    "dev:api": "npm run dev -w apps/api",
    "infra:up": "docker compose up -d --wait",
    "infra:down": "docker compose down",
    "infra:status": "docker compose ps",
    "infra:postgres:portable": "powershell -ExecutionPolicy Bypass -File tools/dev/portable-postgres.ps1 -Action Start",
    "infra:postgres:portable:stop": "powershell -ExecutionPolicy Bypass -File tools/dev/portable-postgres.ps1 -Action Stop",
    "dev:desktop": "concurrently -k -n api,web,desktop -c cyan,green,magenta \"npm run dev -w apps/api\" \"npm run dev -w apps/web\" \"wait-on http://127.0.0.1:4000/health http://127.0.0.1:3000 && npm run dev -w apps/desktop\"",
    "desktop:runtime": "npm run runtime:build -w apps/desktop",
    "desktop:package": "npm run runtime:build -w apps/desktop && npm run package -w apps/desktop",
    "desktop:make": "npm run runtime:build -w apps/desktop && npm run make -w apps/desktop",
    "desktop:check": "node tools/harness/windows-desktop-check.mjs",
    "desktop:smoke": "powershell -ExecutionPolicy Bypass -File tools/harness/windows-package-smoke.ps1",
    "desktop:renderer-smoke": "node tools/harness/windows-renderer-auth-smoke.mjs",
    "auth:integration": "node tools/harness/auth-persistence.mjs",
    "invitation:integration": "node tools/harness/invitation-consent.mjs",
    "conversation:integration": "node tools/harness/conversation-persistence.mjs",
    "contacts:integration": "node tools/harness/contacts-privacy.mjs",
    "build": "npm run build -w packages/contracts && npm run build -w apps/api && npm run build -w apps/web && npm run build -w apps/desktop",
    "typecheck": "npm run typecheck -w packages/contracts && npm run typecheck -w apps/api && npm run typecheck -w apps/web && npm run typecheck -w apps/desktop",
    "test": "npm run test -w packages/contracts",
    "smoke": "node tools/harness/smoke.mjs",
    "schema:check": "node tools/harness/schema-check.mjs",
    "harness": "powershell -ExecutionPolicy Bypass -File tools/harness/hahatalk-harness.ps1",
    "report:new": "powershell -ExecutionPolicy Bypass -File tools/harness/new-obsidian-report.ps1",
    "dev:loop": "powershell -ExecutionPolicy Bypass -File tools/harness/development-loop.ps1",
    "lint": "npm run typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "socket.io-client": "^4.8.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.3"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "tar": "7.5.19",
    "tmp": "0.2.7"
  }
}
