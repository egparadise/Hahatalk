{
  "schemaVersion": 1,
  "environment": "production",
  "livekit": {
    "publicUrl": "wss://livekit.company.invalid",
    "workerUrl": "wss://livekit-internal.company.invalid",
    "redisAddress": "redis-internal.company.invalid:6379",
    "nodeIp": null,
    "useExternalIp": true,
    "rtc": {
      "tcpPort": 7881,
      "portRangeStart": 50000,
      "portRangeEnd": 60000
