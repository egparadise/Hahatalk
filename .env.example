# Local development only. Production secrets must come from a secret manager.
DATABASE_URL=postgresql://hahatalk:hahatalk_dev_only@127.0.0.1:54329/hahatalk
POSTGRES_DB=hahatalk
POSTGRES_PASSWORD=hahatalk_dev_only
POSTGRES_USER=hahatalk

REDIS_PASSWORD=hahatalk_redis_dev_only
REDIS_URL=redis://:hahatalk_redis_dev_only@127.0.0.1:6389

MINIO_ROOT_PASSWORD=hahatalk_minio_dev_only
MINIO_ROOT_USER=hahatalk
S3_BUCKET=hahatalk-dev
S3_ENDPOINT=http://127.0.0.1:9000

# LiveKit media. Use trusted TLS/WSS and secret-manager values outside local development.
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=replace_for_nonlocal_use

# Stage 6E recording. Central server/development only: never ship these credentials on an end-user PC.
# Egress is a separate service; keep disabled until it and protected storage are ready.
LIVEKIT_EGRESS_ENABLED=0
LIVEKIT_EGRESS_S3_BUCKET=hahatalk-recordings-dev
LIVEKIT_EGRESS_S3_REGION=ap-northeast-2
LIVEKIT_EGRESS_S3_ACCESS_KEY=replace_me
LIVEKIT_EGRESS_S3_SECRET_KEY=replace_me
# LIVEKIT_EGRESS_S3_ENDPOINT=http://127.0.0.1:9000
# LIVEKIT_EGRESS_S3_FORCE_PATH_STYLE=1
# LIVEKIT_EGRESS_S3_SESSION_TOKEN=
# HAHATALK_LIVEKIT_WEBHOOK_URL=https://hahatalk.example.com/provider/livekit/webhook

COOKIE_SECURE=false
SESSION_COOKIE_NAME=hahatalk_dev_session
WEB_ORIGIN=http://127.0.0.1:3000

# Stage 10 mobile push. Generate independent secret-manager values; do not reuse these placeholders.
MOBILE_PUSH_TOKEN_KEY=replace_with_32_byte_base64_key
MOBILE_PUSH_TOKEN_KEY_ID=replace_with_rotation_key_id
MOBILE_PUSH_WORKER_TOKEN=replace_with_long_random_worker_token

# Stage 11 operations. Public production must use a non-superuser/non-BYPASSRLS role.
HAHATALK_DATABASE_MODE=external
OPS_METRICS_TOKEN=replace_with_long_random_metrics_token
AUDIT_EXPORT_TTL_MINUTES=15
HAHATALK_DESTRUCTIVE_LIFECYCLE_ENABLED=false
# Set only when the API is directly behind a trusted loopback reverse proxy.
HAHATALK_TRUST_PROXY=disabled
